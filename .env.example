# ============================================
# MemoryNexus 环境变量配置
# 复制此文件为 .env 并填入你的配置
# ============================================

# ------------------
# 数据库
# ------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memorynexus
DB_PASSWORD=postgres

# ------------------
# Redis
# ------------------
REDIS_URL=redis://localhost:6379/0

# ------------------
# Qdrant 向量数据库
# ------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=memorynexus_memories

# ------------------
# MinIO 对象存储
# ------------------
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000

# ------------------
# AI 服务
# ------------------
# OpenAI (可选)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# 本地 Ollama (可选)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# Embedding 模型
MEMORYNEXUS_EMBEDDING_PROVIDER=openai
# 本地 smoke test 可设为 local：使用 deterministic hash embedding，不调用外部 API。
# 生产语义检索仍建议使用 openai 或兼容的真实 embedding provider。
EMBEDDING_MODEL=text-embedding-3-small
# Rust 服务也兼容 OPENAI_EMBEDDING_MODEL；未设置时会读取 EMBEDDING_MODEL。

# ------------------
# 安全
# ------------------
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------
# CORS
# ------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ------------------
# 邮件服务 (可选，用于发送提醒)
# ------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@memorynexus.local

# ------------------
# 推送通知 (可选)
# ------------------
# 飞书 Webhook
FEISHU_WEBHOOK=

# 微信 (需要企业微信)
WECOM_WEBHOOK=

# ------------------
# 日志
# ------------------
LOG_LEVEL=INFO
