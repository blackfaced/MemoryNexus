# Runtime Docker Compose settings for Local One-click Profile.
# Copy to .env.runtime for local edits, or pass this file directly to
# `docker compose --env-file`.

POSTGRES_USER=memorynexus
POSTGRES_PASSWORD=memorynexus_local
POSTGRES_DB=memorynexus
POSTGRES_PORT=5432

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Export these values when starting the release `memorynexus` API binary on the
# host. `docker compose --env-file` only configures Docker services; it does not
# automatically export variables into your shell.
DATABASE_URL=postgresql://memorynexus:memorynexus_local@localhost:5432/memorynexus
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=memorynexus_runtime_local
MEMORYNEXUS_EMBEDDING_PROVIDER=local
MEMORYNEXUS_BIND_ADDR=0.0.0.0:8080

# Use a long random value for any real local install.
JWT_SECRET=change-this-local-runtime-secret
